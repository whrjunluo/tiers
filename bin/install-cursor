#!/usr/bin/env bash
# Install this plugin into Cursor on the current machine.
#
# Cursor 原生读取 skill 目录（~/.cursor/skills 及兼容的 ~/.claude、~/.codex），
# 故这里把四个 skill 软链进 ~/.cursor/skills/，并初始化跨工具统一的全局数据区。
#
# 关于 hook：Cursor 的 beforeSubmitPrompt（对应 Claude 的 UserPromptSubmit）只能
# 放行/拦截、无法向模型注入上下文，故不安装进化提醒 hook —— 该能力由常驻的
# dev-workflow skill 兜底（功能完整，仅少了 Claude/Codex 上那层自动提醒）。
set -euo pipefail

PLUGIN_ROOT="${DEV_WORKFLOW_PLUGIN_ROOT:-${CURSOR_PLUGIN_ROOT:-$(cd "$(dirname "$0")/.." && pwd)}}"
CURSOR_HOME_DIR="${CURSOR_HOME:-$HOME/.cursor}"
YES=0
INSTALL_DEPS=0

while [ "${1:-}" ]; do
  case "$1" in
    --cursor-home) CURSOR_HOME_DIR="$2"; shift 2 ;;
    --yes|-y) YES=1; shift ;;
    --install-deps) INSTALL_DEPS=1; shift ;;
    *) echo "Unknown argument: $1" >&2; exit 2 ;;
  esac
done

die() { echo "✗ $1" >&2; exit 1; }

[ -f "$PLUGIN_ROOT/.cursor-plugin/plugin.json" ] || die "Missing .cursor-plugin/plugin.json in $PLUGIN_ROOT"
[ -d "$PLUGIN_ROOT/skills/dev-workflow" ] || die "Missing skills/dev-workflow in $PLUGIN_ROOT"
[ -d "$PLUGIN_ROOT/skills/grill-me" ] || die "Missing skills/grill-me in $PLUGIN_ROOT"
[ -d "$PLUGIN_ROOT/skills/grilling" ] || die "Missing skills/grilling in $PLUGIN_ROOT"
[ -d "$PLUGIN_ROOT/skills/external-agent" ] || die "Missing skills/external-agent in $PLUGIN_ROOT"

timestamp() { date +%Y%m%d-%H%M%S; }

link_or_backup() {
  local target="$1" dest="$2" backup_root="$3"
  mkdir -p "$(dirname "$dest")" "$backup_root"
  if [ -L "$dest" ] || [ ! -e "$dest" ]; then
    ln -sfn "$target" "$dest"
    return
  fi

  local backup="$backup_root/$(basename "$dest").$(timestamp)"
  mv "$dest" "$backup"
  ln -sfn "$target" "$dest"
  echo "ℹ Existing $(basename "$dest") moved to $backup"
}

install_links() {
  local skills_dir="$CURSOR_HOME_DIR/skills"
  local backup_root="$CURSOR_HOME_DIR/skills-backup"

  mkdir -p "$skills_dir"
  link_or_backup "$PLUGIN_ROOT/skills/dev-workflow" "$skills_dir/dev-workflow" "$backup_root"
  link_or_backup "$PLUGIN_ROOT/skills/grill-me" "$skills_dir/grill-me" "$backup_root"
  link_or_backup "$PLUGIN_ROOT/skills/grilling" "$skills_dir/grilling" "$backup_root"
  link_or_backup "$PLUGIN_ROOT/skills/external-agent" "$skills_dir/external-agent" "$backup_root"
}

if [ "$YES" != 1 ]; then
  echo "This will install dev-workflow into Cursor home: $CURSOR_HOME_DIR"
  read -r -p "Continue? [y/N] " answer
  [ "$answer" = "y" ] || [ "$answer" = "Y" ] || exit 0
fi

install_links

# 跨工具统一的全局数据区（~/.dev-workflow），首次会从旧版分目录迁移历史记录。
DEV_WORKFLOW_PLUGIN_ROOT="$PLUGIN_ROOT" "$PLUGIN_ROOT/scripts/learnings.sh" ready >/dev/null || true

# 伴侣 skill（Cursor 走 skill 文件，非 /plugin）。默认只提示；--install-deps 才自动装。
have_skill_dir() {
  find "$CURSOR_HOME_DIR/skills" "$HOME/.claude" "$HOME/.codex/skills" \
    -maxdepth 4 -type d -name "$1" 2>/dev/null | grep -q .
}
add_companion() { # $1=repo  $2=display
  echo "ℹ 未检测到 $2 —— Cursor 安装： npx skills@latest add $1"
  if [ "$INSTALL_DEPS" = 1 ]; then
    echo "→ 安装 $2 …"
    npx -y skills@latest add "$1" || echo "  ⚠ 自动安装失败，请手动跑上面的命令。"
  fi
}
have_skill_dir '*superpowers*' || add_companion obra/superpowers "superpowers（L1 完整 skill 链）"
have_skill_dir grill-with-docs || add_companion mattpocock/skills "grill-with-docs（内置 grilling 的可选升级）"

echo "✓ Installed dev-workflow for Cursor"
echo "✓ Plugin: $PLUGIN_ROOT"
echo "✓ Skills: $CURSOR_HOME_DIR/skills/dev-workflow, $CURSOR_HOME_DIR/skills/grill-me, $CURSOR_HOME_DIR/skills/grilling, $CURSOR_HOME_DIR/skills/external-agent"
echo "✓ Data:   ${DEV_WORKFLOW_DATA:-$HOME/.dev-workflow}（跨工具共享）"
echo "ℹ 进化提醒在 Cursor 由常驻 skill 兜底（Cursor 不支持 prompt 提交时注入上下文，故无 hook）。"
echo "Reload Window 或完全重启 Cursor，让 skill 索引重新加载。"
