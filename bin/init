#!/usr/bin/env bash
# dev-workflow 安装器：建数据区、确保 gitignore、引导/可选安装伴侣依赖、检测 codegraph。
# 默认只「检测 + 打印安装命令」；加 --install-deps 才真正动手装可脚本化的依赖（opt-in）。
set -euo pipefail
PLUGIN_ROOT="${DEV_WORKFLOW_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-${CURSOR_PLUGIN_ROOT:-$(cd "$(dirname "$0")/.." && pwd)}}}}"
source "$PLUGIN_ROOT/scripts/lib.sh"

REPO="$PWD"; YES=0; INSTALL_DEPS=0
while [ "${1:-}" ]; do case "$1" in
  --repo) REPO="$2"; shift 2;;
  --yes|-y) YES=1; shift;;
  --install-deps) INSTALL_DEPS=1; shift;;
  *) shift;;
esac; done

# 运行平台探测（决定 superpowers 装法 / codegraph MCP 平台）
if [ -n "${CODEX_PLUGIN_ROOT:-}" ] || [ -n "${CODEX_HOME:-}" ]; then
  PLATFORM=codex
elif [ -n "${CURSOR_PLUGIN_ROOT:-}" ] || [ -n "${CURSOR_HOME:-}" ]; then
  PLATFORM=cursor
else
  PLATFORM=claude-code
fi

have() { command -v "$1" >/dev/null 2>&1; }
# 1. 数据区 + LEARNINGS
dw_ensure_learnings
echo "✓ 用户数据区：$(dw_data_dir)"

# 2. gitignore 续行状态与本地验收证据
GI="$REPO/.gitignore"
grep -qxF "docs/superpowers/.workflow-state.yaml" "$GI" 2>/dev/null || \
  echo "docs/superpowers/.workflow-state.yaml" >> "$GI"
grep -qxF "docs/superpowers/.workflow-evidence/" "$GI" 2>/dev/null || \
  echo "docs/superpowers/.workflow-evidence/" >> "$GI"
echo "✓ 已确保 .gitignore 忽略续行状态与本地验收证据"

# 3. capability doctor（统一检测；默认只提示，--install-deps 才安装可脚本化依赖）
doctor_args=(--repo "$REPO" --platform "$PLATFORM")
if [ "$INSTALL_DEPS" = 1 ]; then doctor_args+=(--install-deps); fi
CODEX_HOME="${CODEX_HOME:-}" "$PLUGIN_ROOT/scripts/dependency-doctor.sh" "${doctor_args[@]}"

# 4. codegraph MCP（CLI 缺失时 doctor 已提示/安装；这里只做项目级注册）
if have code-review-graph; then
  echo "✓ code-review-graph 可用 —— codegraph 判级校验已就绪（Mode A）"
  if [ "$YES" = 1 ] || { read -rp "为本 repo 注册 codegraph MCP（解锁事前依赖查询 Mode B）? [y/N] " a; [ "$a" = y ]; }; then
    plat="${DEV_WORKFLOW_CODEGRAPH_PLATFORM:-$PLATFORM}"
    (cd "$REPO" && code-review-graph install --platform "$plat" --no-hooks --no-skills --no-instructions -y) || true
  fi
fi
echo "✓ dev-workflow 安装完成"
