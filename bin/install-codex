#!/usr/bin/env bash
# Install this plugin into Codex on the current machine.
set -euo pipefail

PLUGIN_ROOT="${DEV_WORKFLOW_PLUGIN_ROOT:-$(cd "$(dirname "$0")/.." && pwd)}"
CODEX_HOME_DIR="${CODEX_HOME:-$HOME/.codex}"
YES=0

while [ "${1:-}" ]; do
  case "$1" in
    --codex-home) CODEX_HOME_DIR="$2"; shift 2 ;;
    --yes|-y) YES=1; shift ;;
    *) echo "Unknown argument: $1" >&2; exit 2 ;;
  esac
done

PLUGIN_NAME="dev-workflow-plugin"
PLUGIN_VERSION="0.1.0"
MARKETPLACE_NAME="local"
CONFIG="$CODEX_HOME_DIR/config.toml"

die() { echo "✗ $1" >&2; exit 1; }

[ -f "$PLUGIN_ROOT/.codex-plugin/plugin.json" ] || die "Missing .codex-plugin/plugin.json in $PLUGIN_ROOT"
[ -d "$PLUGIN_ROOT/skills/dev-workflow" ] || die "Missing skills/dev-workflow in $PLUGIN_ROOT"

timestamp() { date +%Y%m%d-%H%M%S; }

link_or_backup() {
  local target="$1" dest="$2" backup_root="$3"
  mkdir -p "$(dirname "$dest")" "$backup_root"
  if [ -L "$dest" ] || [ ! -e "$dest" ]; then
    ln -sfn "$target" "$dest"
    return
  fi

  local backup="$backup_root/$(basename "$dest").$(timestamp)"
  mv "$dest" "$backup"
  ln -sfn "$target" "$dest"
  echo "ℹ Existing $(basename "$dest") moved to $backup"
}

write_marketplace() {
  local marketplace="$CODEX_HOME_DIR/plugins/local-marketplace/.agents/plugins/marketplace.json"
  mkdir -p "$(dirname "$marketplace")"
  python3 - "$marketplace" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
data = {
    "name": "local",
    "interface": {"displayName": "Local"},
    "plugins": [
        {
            "name": "dev-workflow-plugin",
            "source": {"source": "local", "path": "./plugins/dev-workflow-plugin"},
            "policy": {"installation": "AVAILABLE", "authentication": "ON_INSTALL"},
            "category": "Developer Tools",
        }
    ],
}
path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n")
PY
}

ensure_config() {
  mkdir -p "$CODEX_HOME_DIR"
  touch "$CONFIG"
  python3 - "$CONFIG" "$CODEX_HOME_DIR/plugins/local-marketplace" <<'PY'
import re
import sys
from pathlib import Path

config = Path(sys.argv[1])
marketplace_path = sys.argv[2]
text = config.read_text()

def ensure_block(source, header, body):
    if header not in source:
        return source.rstrip() + "\n\n" + header + "\n" + body.rstrip() + "\n"
    return source

text = ensure_block(
    text,
    "[marketplaces.local]",
    f'last_updated = "1970-01-01T00:00:00Z"\nsource_type = "local"\nsource = "{marketplace_path}"',
)
text = ensure_block(text, '[plugins."dev-workflow-plugin@local"]', "enabled = true")

pattern = re.compile(r'(\[plugins\."dev-workflow-plugin@local"\]\n)(.*?)(?=\n\[|\Z)', re.S)
match = pattern.search(text)
if match:
    body = match.group(2)
    if re.search(r"^enabled\s*=", body, re.M):
        body = re.sub(r"^enabled\s*=.*$", "enabled = true", body, flags=re.M)
    else:
        body = body.rstrip() + "\nenabled = true\n"
    text = text[: match.start()] + match.group(1) + body + text[match.end() :]

config.write_text(text)
PY
}

install_links() {
  local cache_dir="$CODEX_HOME_DIR/plugins/cache/$MARKETPLACE_NAME/$PLUGIN_NAME"
  local marketplace_plugins="$CODEX_HOME_DIR/plugins/local-marketplace/plugins"
  local backup_root="$CODEX_HOME_DIR/skills-backup"

  mkdir -p "$cache_dir" "$marketplace_plugins" "$CODEX_HOME_DIR/skills"
  link_or_backup "$PLUGIN_ROOT" "$cache_dir/$PLUGIN_VERSION" "$CODEX_HOME_DIR/plugins-backup"
  ln -sfn "$cache_dir/$PLUGIN_VERSION" "$cache_dir/latest"
  link_or_backup "$PLUGIN_ROOT" "$marketplace_plugins/$PLUGIN_NAME" "$CODEX_HOME_DIR/plugins-backup"

  link_or_backup "$PLUGIN_ROOT/skills/dev-workflow" "$CODEX_HOME_DIR/skills/dev-workflow" "$backup_root"
  link_or_backup "$PLUGIN_ROOT/skills/grill-me" "$CODEX_HOME_DIR/skills/grill-me" "$backup_root"
}

if [ "$YES" != 1 ]; then
  echo "This will install dev-workflow into Codex home: $CODEX_HOME_DIR"
  read -r -p "Continue? [y/N] " answer
  [ "$answer" = "y" ] || [ "$answer" = "Y" ] || exit 0
fi

write_marketplace
install_links
ensure_config

CODEX_HOME="$CODEX_HOME_DIR" DEV_WORKFLOW_PLUGIN_ROOT="$PLUGIN_ROOT" "$PLUGIN_ROOT/scripts/learnings.sh" ready >/dev/null || true

echo "✓ Installed dev-workflow-plugin for Codex"
echo "✓ Plugin: $PLUGIN_ROOT"
echo "✓ Skills: $CODEX_HOME_DIR/skills/dev-workflow, $CODEX_HOME_DIR/skills/grill-me"
echo "✓ Config: $CONFIG"
echo "Restart Codex or open a new Codex conversation to reload the skill index."
